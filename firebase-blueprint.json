{
  "entities": {
    "Submission": {
      "title": "Submission",
      "description": "A job posting or administrative entry",
      "type": "object",
      "properties": {
        "formType": { "type": "string" },
        "postName": { "type": "string" },
        "departmentName": { "type": "string" },
        "importantDates": { "type": "string" },
        "applicationFees": { "type": "string" },
        "ageLimit": { "type": "string" },
        "eligibility": { "type": "string" },
        "applyLink": { "type": "string" },
        "notificationLink": { "type": "string" },
        "officialWebsite": { "type": "string" },
        "postWiseDetails": { "type": "string" },
        "howToFill": { "type": "string" },
        "remark": { "type": "string" },
        "submittedBy": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["formType", "postName", "submittedBy", "timestamp"]
    },
    "Job": {
      "title": "Job",
      "description": "Legacy job entry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "organization": { "type": "string" }
      }
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "User subscriber for notifications",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Collection of all postings"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Legacy jobs"
    },
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Subscribers"
    }
  }
}
